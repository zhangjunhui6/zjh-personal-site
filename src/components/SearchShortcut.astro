---
import { site } from '@/config/site';
import type { SiteLanguage } from '@/config/site';
import { localizedPath, uiText } from '@/utils/i18n';

interface Props {
  label?: string;
  placeholder?: string;
  collection?: 'notes' | 'journal' | 'projects';
  lang?: SiteLanguage;
  class?: string;
}

const {
  collection,
  lang = site.defaultLang,
  class: className = '',
} = Astro.props;
const text = uiText[lang];
const label = Astro.props.label ?? (lang === 'en' ? 'Search the site' : '搜索全站内容');
const placeholder = Astro.props.placeholder ?? (lang === 'en' ? 'Search titles, tags, body text' : '搜索标题、标签、正文');
const inputId = collection ? `${collection}-search-shortcut` : 'site-search-shortcut';
const scopeLabel = collection ? text.collectionLabels[collection] : text.searchScopeAll;
---

<form action={localizedPath('/search/', lang)} method="get" role="search" class:list={['search-shortcut', className]}>
  <div class="rounded-lg border border-[var(--color-line)] bg-[rgba(255,253,248,0.86)] p-3 shadow-[0_18px_48px_rgba(78,68,52,0.08)] backdrop-blur sm:p-4">
    <div class="mb-3 flex items-center justify-between gap-3">
      <label class="text-sm font-semibold text-[var(--color-ink)]" for={inputId}>{label}</label>
      <span class="shrink-0 rounded-full border border-[var(--color-line)] bg-[var(--color-paper)] px-3 py-1 text-xs font-medium text-[var(--color-muted)]">
        {scopeLabel}
      </span>
    </div>
    <div class="grid gap-2 sm:grid-cols-[minmax(0,1fr)_auto]">
      <div class="relative">
        <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-lg text-[var(--color-muted)]" aria-hidden="true">⌕</span>
        <input
          id={inputId}
          name="q"
          type="search"
          placeholder={placeholder}
          autocomplete="off"
          class="min-h-12 w-full rounded-md border border-[var(--color-line)] bg-[var(--color-surface)] px-4 pl-10 text-base text-[var(--color-ink)] outline-none transition placeholder:text-[rgba(104,117,111,0.82)] focus:border-[var(--color-leaf)] focus:ring-2 focus:ring-[rgba(47,93,80,0.16)]"
        />
      </div>
      <input name="type" type="hidden" value={collection ?? 'all'} />
      <button
        type="submit"
        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-[var(--color-leaf)] bg-[var(--color-leaf)] px-5 text-sm font-semibold text-white transition hover:border-[var(--color-ink)] hover:bg-[var(--color-ink)] focus:outline-none focus:ring-2 focus:ring-[rgba(47,93,80,0.18)] sm:min-w-24"
      >
        <span aria-hidden="true">↵</span>
        <span>{text.searchSubmit}</span>
      </button>
    </div>
    <p class="mb-0 mt-3 text-xs leading-5 text-[var(--color-muted)]">{text.searchHint}</p>
  </div>
</form>
