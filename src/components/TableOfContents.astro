---
import { site } from '@/config/site';
import type { SiteLanguage } from '@/config/site';
import { uiText } from '@/utils/i18n';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  lang?: SiteLanguage;
}

const { headings, lang = site.defaultLang } = Astro.props;
const text = uiText[lang];
---

<nav class="toc-panel" aria-label={text.tocLabel}>
  <p class="toc-title">{text.tocTitle}</p>
  <ol class="toc-list">
    {headings.map((heading) => (
      <li class={`toc-item toc-link-depth-${heading.depth}`}>
        <a class="toc-link" href={`#${heading.slug}`}>{heading.text}</a>
      </li>
    ))}
  </ol>
</nav>
