---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

<nav class="toc-panel" aria-label="文章目录">
  <p class="toc-title">本文目录</p>
  <ol class="toc-list">
    {headings.map((heading) => (
      <li class={`toc-item toc-link-depth-${heading.depth}`}>
        <a class="toc-link" href={`#${heading.slug}`}>{heading.text}</a>
      </li>
    ))}
  </ol>
</nav>
