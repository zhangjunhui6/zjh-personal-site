---
import ContentLayout from '@/layouts/ContentLayout.astro';

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type DraftModule = {
  frontmatter: {
    title: string;
    description: string;
    date: string | Date;
    tags?: string[];
  };
  Content?: any;
  default: any;
  getHeadings?: () => Heading[] | Promise<Heading[]>;
};

const order = [
  'robot-vla-docker-experiment-roadmap',
  'robot-vla-vision-language-action-intro',
  'robot-vla-datasets-lerobot-openx-droid',
  'robot-vla-lerobot-docker-start',
  'robot-vla-openvla-policy-notes',
  'robot-vla-smolvla-first-experiments',
  'robot-vla-openpi-pi0-flow-matching',
  'robot-vla-libero-evaluation',
  'robot-vla-finetuning-lora-post-training',
  'robot-vla-gr00t-humanoid-system',
];

export function getStaticPaths() {
  const draftModules = import.meta.glob<DraftModule>('../../../../../docs/drafts/robotics/vla/*.md');

  return Object.keys(draftModules)
    .filter((path) => !path.endsWith('-en.md'))
    .map((path) => ({
      params: { slug: path.split('/').pop()?.replace(/\.md$/, '') },
      props: { path },
    }));
}

const draftModules = import.meta.glob<DraftModule>('../../../../../docs/drafts/robotics/vla/*.md');
const { path } = Astro.props;
const module = await draftModules[path]();
const { frontmatter } = module;
const Content = module.Content ?? module.default;
const headings: Heading[] = typeof module.getHeadings === 'function' ? await module.getHeadings() : [];
const currentSlug = path.split('/').pop()?.replace(/\.md$/, '') ?? '';
const navItems = (
  await Promise.all(
    order.map(async (slug) => {
      const itemPath = Object.keys(draftModules).find((candidate) => candidate.endsWith(`/${slug}.md`));
      if (!itemPath) return undefined;
      const itemModule = await draftModules[itemPath]();
      return { slug, title: itemModule.frontmatter.title };
    }),
  )
).filter((item): item is { slug: string; title: string } => Boolean(item));
const currentIndex = navItems.findIndex((item) => item.slug === currentSlug);
const currentNumber = currentIndex >= 0 ? currentIndex + 1 : undefined;
const previous = currentIndex > 0 ? navItems[currentIndex - 1] : undefined;
const next = currentIndex >= 0 && currentIndex < navItems.length - 1 ? navItems[currentIndex + 1] : undefined;
---

<ContentLayout
  title={frontmatter.title}
  description={frontmatter.description}
  date={new Date(frontmatter.date)}
  tags={frontmatter.tags}
  headings={headings}
  lang="zh"
  showLanguageToggle={false}
>
  <p class="mb-3 text-sm font-semibold text-[var(--color-muted)]">
    {currentNumber ? `第 ${currentNumber} / ${navItems.length} 篇` : 'VLA 论文精读'}
  </p>
  <p class="mb-8">
    <a href="/drafts/robotics/vla/">← 返回 VLA 论文精读草稿目录</a>
  </p>
  <Content />
  <nav class="mt-12 grid gap-4 border-t border-[var(--color-line)] pt-8 md:grid-cols-2" aria-label="VLA 论文精读上一篇和下一篇">
    {
      previous ? (
        <a
          class="block rounded-lg border border-[var(--color-line)] bg-[var(--color-surface)] px-5 py-4 no-underline transition-colors hover:border-[var(--color-leaf)]"
          href={`/drafts/robotics/vla/${previous.slug}/`}
        >
          <span class="block text-xs font-semibold text-[var(--color-muted)]">上一篇</span>
          <span class="mt-2 block font-semibold text-[var(--color-leaf)]">{previous.title}</span>
        </a>
      ) : (
        <span class="block rounded-lg border border-dashed border-[var(--color-line)] px-5 py-4 text-sm text-[var(--color-muted)]">已经是第一篇</span>
      )
    }
    {
      next ? (
        <a
          class="block rounded-lg border border-[var(--color-line)] bg-[var(--color-surface)] px-5 py-4 text-right no-underline transition-colors hover:border-[var(--color-leaf)]"
          href={`/drafts/robotics/vla/${next.slug}/`}
        >
          <span class="block text-xs font-semibold text-[var(--color-muted)]">下一篇</span>
          <span class="mt-2 block font-semibold text-[var(--color-leaf)]">{next.title}</span>
        </a>
      ) : (
        <span class="block rounded-lg border border-dashed border-[var(--color-line)] px-5 py-4 text-right text-sm text-[var(--color-muted)]">已经是最后一篇</span>
      )
    }
  </nav>
</ContentLayout>
