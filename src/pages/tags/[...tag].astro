---
import { getCollection } from 'astro:content';
import ContentCard from '@/components/ContentCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isPublished } from '@/utils/collections';
import {
  collectTagSummaries,
  filterItemsByTag,
  tagSlug,
  toTaggedContentItems,
} from '@/utils/taxonomy';

interface Props {
  tag: string;
}

export async function getStaticPaths() {
  const notes = (await getCollection('notes')).filter(isPublished);
  const journal = (await getCollection('journal')).filter(isPublished);
  const items = toTaggedContentItems(notes, journal);

  return collectTagSummaries(items).map(({ tag }) => ({
    params: { tag: tagSlug(tag) },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const notes = (await getCollection('notes')).filter(isPublished);
const journal = (await getCollection('journal')).filter(isPublished);
const entries = filterItemsByTag(toTaggedContentItems(notes, journal), tag);
const description = `查看与「${tag}」相关的记录和生活内容。`;
---

<BaseLayout title={`标签：${tag}`} description={description}>
  <section class="container py-12">
    <a class="mb-6 inline-block text-sm text-[var(--color-muted)]" href="/tags/">← 所有标签</a>
    <h1 class="mb-4 text-4xl font-semibold">#{tag}</h1>
    <p class="mb-8 max-w-2xl leading-8 text-[var(--color-muted)]">{description}</p>

    <div class="grid gap-4 md:grid-cols-2">
      {entries.map((entry) => (
        <ContentCard
          title={entry.title}
          description={entry.description}
          date={entry.date}
          href={entry.href}
          label={entry.label}
        />
      ))}
    </div>
  </section>
</BaseLayout>
