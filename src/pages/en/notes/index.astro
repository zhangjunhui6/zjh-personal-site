---
import { getCollection } from 'astro:content';
import SearchShortcut from '@/components/SearchShortcut.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isPublished, notesByPinnedThenNewest } from '@/utils/collections';
import { entriesForLanguage, localizedContentHref } from '@/utils/i18n';
import { buildNoteTopicDomains } from '@/utils/noteHub';
import { formatDate } from '@/utils/dates';

const lang = 'en';
const notes = notesByPinnedThenNewest(entriesForLanguage((await getCollection('notes')).filter(isPublished), lang));
const topicDomains = buildNoteTopicDomains(notes, lang);
const latestNotes = notes.slice(0, 8);
const noteTopicDomains = topicDomains;
const articleLabel = (count: number) => `${count} ${count === 1 ? 'article' : 'articles'}`;
const text = {
  topicEyebrow: 'Content Map',
  topicGuide: 'Topic Guide',
  topicGuideDescription: 'Start from a domain, then follow the topic path into the articles. Use search when you already know what you need.',
  latestNotes: 'Latest Notes',
  latestNotesDescription: 'Recent updates in publishing order.',
  viewAll: 'View all',
};
---

<BaseLayout title="Notes" description="Articles, technical notes, reading notes, and long-running thoughts." lang={lang}>
  <section class="container py-12">
    <h1 class="mb-4 text-4xl font-semibold">Notes</h1>
    <p class="mb-6 max-w-2xl leading-8 text-[var(--color-muted)]">Articles, technical notes, reading notes, and questions still taking shape.</p>
    <SearchShortcut class="mb-12 max-w-2xl" label="Search notes" placeholder="Search note titles, tags, body text" collection="notes" lang={lang} />

    <section class="mb-14">
      <div class="mb-7 max-w-3xl">
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-leaf)]">{text.topicEyebrow}</p>
        <h2 class="m-0 text-3xl font-semibold leading-tight">{text.topicGuide}</h2>
        <p class="mb-0 mt-3 leading-7 text-[var(--color-muted)]">{text.topicGuideDescription}</p>
      </div>

      <div class="space-y-10">
        {noteTopicDomains.map((domain) => (
          <section>
            <div class="mb-4 flex flex-col gap-2 border-b border-[var(--color-line)] pb-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <h3 class="m-0 text-2xl font-semibold leading-tight">{domain.localizedTitle}</h3>
                <p class="mb-0 mt-2 max-w-3xl leading-7 text-[var(--color-muted)]">{domain.localizedDescription}</p>
              </div>
              <span class="text-sm font-semibold text-[var(--color-muted)]">
                {articleLabel(domain.articleCount)}
              </span>
            </div>

            <div class="grid gap-4 lg:grid-cols-2">
              {domain.topics.map((topic) => (
                <article class="quiet-card p-5">
                  <div class="mb-3 flex items-start justify-between gap-4">
                    <div>
                      <h4 class="m-0 text-xl font-semibold leading-snug">{topic.localizedTitle}</h4>
                      <p class="mb-0 mt-2 text-sm leading-6 text-[var(--color-muted)]">{topic.localizedDescription}</p>
                    </div>
                    <a
                      class="shrink-0 rounded-full border border-[var(--color-line)] px-3 py-1 text-xs font-semibold text-[var(--color-muted)] no-underline hover:border-[var(--color-leaf)] hover:text-[var(--color-leaf)]"
                      href={topic.href}
                    >
                      {articleLabel(topic.count)}
                    </a>
                  </div>

                  <ol class="m-0 list-none space-y-3 border-t border-[var(--color-line)] px-0 pb-0 pt-4">
                    {topic.featuredEntries.map((entry, index) => (
                      <li class="grid grid-cols-[2rem_1fr] gap-3">
                        <span class="font-mono text-xs leading-6 text-[var(--color-muted)]">
                          {String(index + 1).padStart(2, '0')}
                        </span>
                        <a class="font-semibold leading-6 no-underline hover:text-[var(--color-leaf)]" href={entry.href}>
                          {entry.title}
                        </a>
                      </li>
                    ))}
                  </ol>

                  <a class="mt-4 inline-block text-sm font-semibold text-[var(--color-leaf)] no-underline" href={topic.href}>
                    {text.viewAll}
                  </a>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section>
      <div class="mb-5 flex flex-col gap-2 border-b border-[var(--color-line)] pb-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="m-0 text-2xl font-semibold">{text.latestNotes}</h2>
          <p class="mb-0 mt-2 leading-7 text-[var(--color-muted)]">{text.latestNotesDescription}</p>
        </div>
        <a class="text-sm font-semibold text-[var(--color-leaf)] no-underline" href="/en/archive/">{text.viewAll}</a>
      </div>
      <ol class="m-0 list-none divide-y divide-[var(--color-line)] p-0">
        {latestNotes.map((entry) => (
          <li class="grid gap-2 py-4 md:grid-cols-[10rem_1fr]">
            <time class="text-sm text-[var(--color-muted)]" datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date, lang)}</time>
            <div>
              <a class="font-semibold no-underline" href={localizedContentHref('notes', entry, lang)}>{entry.data.title}</a>
              <p class="mb-0 mt-1 text-sm leading-6 text-[var(--color-muted)]">{entry.data.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </section>
</BaseLayout>
