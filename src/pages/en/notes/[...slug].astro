---
import { getCollection, render } from 'astro:content';
import ContentLayout from '@/layouts/ContentLayout.astro';
import { isPublished } from '@/utils/collections';
import { contentSlug, entriesForLanguage } from '@/utils/i18n';

const lang = 'en';

export async function getStaticPaths() {
  const pathLang = 'en';
  const notes = entriesForLanguage((await getCollection('notes')).filter(isPublished), pathLang);
  return notes.map((entry) => ({ params: { slug: contentSlug(entry) }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  updated={entry.data.updated}
  tags={entry.data.tags}
  headings={headings}
  lang={lang}
>
  <Content />
</ContentLayout>
