---
import { getCollection, render } from 'astro:content';
import ContentLayout from '@/layouts/ContentLayout.astro';
import { isPublished } from '@/utils/collections';
import { contentSlug, entriesForLanguage } from '@/utils/i18n';

const lang = 'en';

export async function getStaticPaths() {
  const pathLang = 'en';
  const projects = entriesForLanguage((await getCollection('projects')).filter(isPublished), pathLang);
  return projects.map((entry) => ({ params: { slug: contentSlug(entry) }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  tags={entry.data.stack}
  headings={headings}
  lang={lang}
  cover={entry.data.cover}
  media={entry.data.media}
>
  <Content />
</ContentLayout>
