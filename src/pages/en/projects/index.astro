---
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/ProjectCard.astro';
import SearchShortcut from '@/components/SearchShortcut.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isPublished, newestFirst } from '@/utils/collections';
import { entriesForLanguage, localizedContentHref } from '@/utils/i18n';

const lang = 'en';
const projects = newestFirst(entriesForLanguage((await getCollection('projects')).filter(isPublished), lang));
---

<BaseLayout title="Projects" description="Small tools, experiments, and work records." lang={lang}>
  <section class="container py-12">
    <h1 class="mb-4 text-4xl font-semibold">Projects</h1>
    <p class="mb-6 max-w-2xl leading-8 text-[var(--color-muted)]">Small tools, website experiments, and longer-running projects.</p>
    <SearchShortcut class="mb-8 max-w-2xl" label="Search projects" placeholder="Search project names, stack, status" collection="projects" lang={lang} />
    <div class="grid gap-4 md:grid-cols-2">
      {projects.map((entry) => (
        <ProjectCard title={entry.data.title} description={entry.data.description} href={localizedContentHref('projects', entry, lang)} stack={entry.data.stack} status={entry.data.status} lang={lang} />
      ))}
    </div>
  </section>
</BaseLayout>
