---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate } from '@/utils/dates';
import { tagHref } from '@/utils/taxonomy';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
}

const { title, description, date, updated, tags = [] } = Astro.props;
const visibleTags = tags.map((tag) => tag.trim()).filter(Boolean);
---

<BaseLayout title={title} description={description}>
  <article class="container py-12">
    <header class="mb-10 max-w-3xl">
      <time class="mb-3 block text-sm text-[var(--color-muted)]" datetime={date.toISOString()}>{formatDate(date)}</time>
      {updated && (
        <time class="mb-3 block text-sm text-[var(--color-muted)]" datetime={updated.toISOString()}>更新于 {formatDate(updated)}</time>
      )}
      <h1 class="m-0 text-4xl font-semibold leading-tight md:text-5xl">{title}</h1>
      <p class="mt-5 text-lg leading-8 text-[var(--color-muted)]">{description}</p>
      {visibleTags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {visibleTags.map((tag) => (
            <a
              class="rounded-full border border-[var(--color-line)] px-3 py-1 text-xs text-[var(--color-muted)] no-underline transition-colors hover:border-[var(--color-leaf)] hover:text-[var(--color-leaf)]"
              href={tagHref(tag)}
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
